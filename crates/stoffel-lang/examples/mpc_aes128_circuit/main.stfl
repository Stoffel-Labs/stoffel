  var x2 = bits_xor_many([m.M16, m.M17, m.M18, m.M19], [m.M13, m.M15, m.M13, t.T25])
  m.M20 = x2[0]
  m.M21 = x2[1]
  m.M22 = x2[2]
  m.M23 = x2[3]
  var x3 = bits_xor_many([m.M22, m.M20], [m.M23, m.M21])
  m.M24 = x3[0]
  m.M27 = x3[1]
  m.M25 = Share.batch_mul(m.M22, m.M20)
  var x4 = bits_xor_many([m.M21, m.M23, m.M27], [m.M25, m.M25, m.M25])
