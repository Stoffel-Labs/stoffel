  t.T21 = x0[9]
  var x1 = bits_xor_many([t.T1, t.U7, t.T3, t.T5, t.T5, t.T7, t.T7, t.T1], [t.T5, t.T7, t.T4, t.T11, t.T12, t.T18, t.T21, t.T12])
  t.T6 = x1[0]
  t.T9 = x1[1]
  t.T13 = x1[2]
  t.T15 = x1[3]
  t.T16 = x1[4]
  t.T19 = x1[5]
  t.T22 = x1[6]
  t.T27 = x1[7]
  var x2 = bits_xor_many([t.T6, t.U7, t.T6, t.T9, t.T1, t.T2, t.T3], [t.T7, t.T6, t.T11, t.T16, t.T19, t.T22, t.T16])
  t.T10 = x2[0]
