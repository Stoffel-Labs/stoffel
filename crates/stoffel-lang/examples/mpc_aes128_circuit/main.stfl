def rcon(round: int64) -> list[list[secret bool]]:
  if round == 1:
    return rcon_1()
  elif round == 2:
    return rcon_2()
  elif round == 3:
    return rcon_3()
  elif round == 4:
    return rcon_4()
  elif round == 5:
    return rcon_5()
  elif round == 6:
    return rcon_6()
  elif round == 7:
    return rcon_7()
  elif round == 8:
    return rcon_8()
  elif round == 9:
    return rcon_9()
  elif round == 10:
    return rcon_10()
  return rcon_10()

def key_expansion(key: list[list[secret bool]]) -> list[list[secret bool]]:
  var words: list[list[list[secret bool]]] = []
  words.append([key[0], key[1], key[2], key[3]])
  words.append([key[4], key[5], key[6], key[7]])
  words.append([key[8], key[9], key[10], key[11]])
  words.append([key[12], key[13], key[14], key[15]])
  for i in 4..44:
    var temp: list[list[secret bool]] = words[i - 1]
    if i % 4 == 0:
      temp = word_xor(sub_word(rot_word(temp)), rcon(i / 4))
    words.append(word_xor(words[i - 4], temp))

  var expanded: list[list[secret bool]] = []
  for i in 0..44:
    expanded.append(words[i][0])
    expanded.append(words[i][1])
    expanded.append(words[i][2])
    expanded.append(words[i][3])
  return expanded

def add_round_key(state: list[list[secret bool]], round_key: list[list[secret bool]], offset: int64) -> list[list[secret bool]]:
  var key_slice: list[list[secret bool]] = []
  for i in 0..16:
    key_slice.append(round_key[offset + i])
  return bytes_xor(state, key_slice)

def sub_bytes(state: list[list[secret bool]]) -> list[list[secret bool]]:
  return aes_sbox_vec(state)

def shift_rows(state: list[list[secret bool]]) -> list[list[secret bool]]:
  return [state[0], state[5], state[10], state[15], state[4], state[9], state[14], state[3], state[8], state[13], state[2], state[7], state[12], state[1], state[6], state[11]]

def mix_single_column(a0: list[secret bool], a1: list[secret bool], a2: list[secret bool], a3: list[secret bool]) -> list[list[secret bool]]:
  var b0 = byte_xor4(mul2(a0), mul3(a1), a2, a3)
  var b1 = byte_xor4(a0, mul2(a1), mul3(a2), a3)
  var b2 = byte_xor4(a0, a1, mul2(a2), mul3(a3))
  var b3 = byte_xor4(mul3(a0), a1, a2, mul2(a3))
  return [b0, b1, b2, b3]

def mix_columns(state: list[list[secret bool]]) -> list[list[secret bool]]:
  var two = mul2_bytes(state)
  var three = mul3_bytes(state)
  var a: list[list[secret bool]] = []
  var b: list[list[secret bool]] = []
  var c: list[list[secret bool]] = []
  var d: list[list[secret bool]] = []
  for col in 0..4:
    var offset: int64 = col * 4
    a.append(two[offset])
    b.append(three[offset + 1])
    c.append(state[offset + 2])
    d.append(state[offset + 3])
    a.append(state[offset])
    b.append(two[offset + 1])
    c.append(three[offset + 2])
    d.append(state[offset + 3])
    a.append(state[offset])
    b.append(state[offset + 1])
    c.append(two[offset + 2])
    d.append(three[offset + 3])
    a.append(three[offset])
    b.append(state[offset + 1])
    c.append(state[offset + 2])
    d.append(two[offset + 3])
  return bytes_xor4(a, b, c, d)

def aes128_encrypt(block: list[list[secret bool]], key: list[list[secret bool]]) -> list[list[secret bool]]:
  var round_key = key_expansion(key)
  var state = add_round_key(block, round_key, 0)
  for round in 1..10:
    state = sub_bytes(state)
    state = shift_rows(state)
    state = mix_columns(state)
    state = add_round_key(state, round_key, round * 16)
  state = sub_bytes(state)
  state = shift_rows(state)
  state = add_round_key(state, round_key, 160)
  return state

def reveal_byte(byte: list[secret bool]) -> int64:
  var value: int64 = 0
  var b0: bool = byte[0].reveal()
  if b0:
    value += 1
  var b1: bool = byte[1].reveal()
  if b1:
    value += 2
  var b2: bool = byte[2].reveal()
  if b2:
    value += 4
  var b3: bool = byte[3].reveal()
  if b3:
    value += 8
  var b4: bool = byte[4].reveal()
  if b4:
    value += 16
  var b5: bool = byte[5].reveal()
  if b5:
    value += 32
  var b6: bool = byte[6].reveal()
  if b6:
    value += 64
  var b7: bool = byte[7].reveal()
  if b7:
    value += 128
  return value

def reveal_block(block: list[list[secret bool]]) -> list[int64]:
  return [reveal_byte(block[0]), reveal_byte(block[1]), reveal_byte(block[2]), reveal_byte(block[3]), reveal_byte(block[4]), reveal_byte(block[5]), reveal_byte(block[6]), reveal_byte(block[7]), reveal_byte(block[8]), reveal_byte(block[9]), reveal_byte(block[10]), reveal_byte(block[11]), reveal_byte(block[12]), reveal_byte(block[13]), reveal_byte(block[14]), reveal_byte(block[15])]

