def rcon(round: int64) -> list[list[secret bool]]:
  if round == 1:
    return rcon_1()
  elif round == 2:
    return rcon_2()
  elif round == 3:
    return rcon_3()
  elif round == 4:
    return rcon_4()
  elif round == 5:
    return rcon_5()
  elif round == 6:
    return rcon_6()
  elif round == 7:
    return rcon_7()
  elif round == 8:
    return rcon_8()
  elif round == 9:
    return rcon_9()
  elif round == 10:
    return rcon_10()
  return rcon_10()

def key_expansion(key: list[list[secret bool]]) -> list[list[secret bool]]:
  var words: list[list[list[secret bool]]] = []
  words.append([key[0], key[1], key[2], key[3]])
  words.append([key[4], key[5], key[6], key[7]])
  words.append([key[8], key[9], key[10], key[11]])
  words.append([key[12], key[13], key[14], key[15]])
  for i in 4..44:
    var temp: list[list[secret bool]] = words[i - 1]
    if i % 4 == 0:
      temp = word_xor(sub_word(rot_word(temp)), rcon(i / 4))
    words.append(word_xor(words[i - 4], temp))

  var expanded: list[list[secret bool]] = []
  for i in 0..44:
    expanded.append(words[i][0])
    expanded.append(words[i][1])
    expanded.append(words[i][2])
    expanded.append(words[i][3])
  return expanded

def add_round_key(state: list[list[secret bool]], round_key: list[list[secret bool]], offset: int64) -> list[list[secret bool]]:
  var key_slice: list[list[secret bool]] = []
  for i in 0..16:
    key_slice.append(round_key[offset + i])
  return bytes_xor(state, key_slice)

def sub_bytes(state: list[list[secret bool]]) -> list[list[secret bool]]:
  return aes_sbox_vec(state)

def shift_rows(state: list[list[secret bool]]) -> list[list[secret bool]]:
  return [state[0], state[5], state[10], state[15], state[4], state[9], state[14], state[3], state[8], state[13], state[2], state[7], state[12], state[1], state[6], state[11]]

def mix_single_column(a0: list[secret bool], a1: list[secret bool], a2: list[secret bool], a3: list[secret bool]) -> list[list[secret bool]]:
  var b0 = byte_xor4(mul2(a0), mul3(a1), a2, a3)
  var b1 = byte_xor4(a0, mul2(a1), mul3(a2), a3)
  var b2 = byte_xor4(a0, a1, mul2(a2), mul3(a3))
  var b3 = byte_xor4(mul3(a0), a1, a2, mul2(a3))
  return [b0, b1, b2, b3]

def mix_columns(state: list[list[secret bool]]) -> list[list[secret bool]]:
  var two = mul2_bytes(state)
  var three = mul3_bytes(state)
  var a: list[list[secret bool]] = []
  var b: list[list[secret bool]] = []
  var c: list[list[secret bool]] = []
  var d: list[list[secret bool]] = []
  for col in 0..4:
    var offset: int64 = col * 4
    a.append(two[offset])
    b.append(three[offset + 1])
    c.append(state[offset + 2])
    d.append(state[offset + 3])
    a.append(state[offset])
    b.append(two[offset + 1])
    c.append(three[offset + 2])
    d.append(state[offset + 3])
    a.append(state[offset])
    b.append(state[offset + 1])
    c.append(two[offset + 2])
    d.append(three[offset + 3])
    a.append(three[offset])
    b.append(state[offset + 1])
    c.append(state[offset + 2])
    d.append(two[offset + 3])
  return bytes_xor4(a, b, c, d)

# Encrypt one block with an already-expanded key schedule. The key schedule over a
# secret key has nearly the same MPC round depth as a block encryption, so expanding it
# once and reusing the round keys across every block roughly halves the work of a
# multi-block mode.
def aes128_encrypt_rk(block: list[list[secret bool]], round_key: list[list[secret bool]]) -> list[list[secret bool]]:
  var state = add_round_key(block, round_key, 0)
  for round in 1..10:
    state = sub_bytes(state)
    state = shift_rows(state)
    state = mix_columns(state)
    state = add_round_key(state, round_key, round * 16)
  state = sub_bytes(state)
  state = shift_rows(state)
  state = add_round_key(state, round_key, 160)
  return state

def aes128_encrypt(block: list[list[secret bool]], key: list[list[secret bool]]) -> list[list[secret bool]]:
  return aes128_encrypt_rk(block, key_expansion(key))

def reveal_byte(byte: list[secret bool]) -> int64:
  var value: int64 = 0
  var b0: bool = byte[0].reveal()
  if b0:
    value += 1
  var b1: bool = byte[1].reveal()
  if b1:
    value += 2
  var b2: bool = byte[2].reveal()
  if b2:
    value += 4
  var b3: bool = byte[3].reveal()
  if b3:
    value += 8
  var b4: bool = byte[4].reveal()
  if b4:
    value += 16
  var b5: bool = byte[5].reveal()
  if b5:
    value += 32
  var b6: bool = byte[6].reveal()
  if b6:
    value += 64
  var b7: bool = byte[7].reveal()
  if b7:
    value += 128
  return value

def reveal_block(block: list[list[secret bool]]) -> list[int64]:
  return [reveal_byte(block[0]), reveal_byte(block[1]), reveal_byte(block[2]), reveal_byte(block[3]), reveal_byte(block[4]), reveal_byte(block[5]), reveal_byte(block[6]), reveal_byte(block[7]), reveal_byte(block[8]), reveal_byte(block[9]), reveal_byte(block[10]), reveal_byte(block[11]), reveal_byte(block[12]), reveal_byte(block[13]), reveal_byte(block[14]), reveal_byte(block[15])]

# --- Inputs come in as secret shares, not program constants ---------------
#
# Each AES byte is 8 secret bits in little-endian order (bit i = 2^i), so a
# client supplies 8 secret inputs per byte and 16 bytes (128 bits) per block.
# `ClientStore.take_share(slot, idx)` returns the secret share the client at
# `slot` fed in at position `idx`; the value never appears in the clear to any
# MPC party.

def take_client_byte(client_slot: int64, byte_index: int64) -> list[secret bool]:
  var byte_bits: list[secret bool] = []
  for bit_index in 0..8:
    var bit: secret bool = ClientStore.take_share_bool(client_slot, byte_index * 8 + bit_index)
    byte_bits.append(bit)
  return byte_bits

def take_client_block(client_slot: int64) -> list[list[secret bool]]:
  var block: list[list[secret bool]] = []
  for byte_index in 0..16:
    block.append(take_client_byte(client_slot, byte_index))
  return block

# --- AES-128 decryption (inverse cipher) ----------------------------------
#
# The forward S-box is `aes_sbox(x) = Affine(GFInverse(x))`. The AES affine map
# A is invertible, so `GFInverse(x) = InvAffine(aes_sbox(x))` and therefore the
# inverse S-box is `InvSBox(y) = GFInverse(InvAffine(y)) =
# InvAffine(aes_sbox(InvAffine(y)))`. This reuses the (already-correct) forward
# S-box circuit and only needs the inverse affine map below — no second 113-gate
# netlist to get wrong.

def inv_affine(y: list[secret bool]) -> list[secret bool]:
  # InvAffine: out[i] = y[(i+2)%8] ^ y[(i+5)%8] ^ y[(i+7)%8], then ^ 0x05.
  # Bits are little-endian (bit i has weight 2^i); 0x05 flips bits 0 and 2.
  var out: list[secret bool] = []
  for i in 0..8:
    var v: secret bool = gate_xor(gate_xor(y[(i + 2) % 8], y[(i + 5) % 8]), y[(i + 7) % 8])
    if i == 0:
      v = gate_not(v)
    if i == 2:
      v = gate_not(v)
    out.append(v)
  return out

def inv_sbox(y: list[secret bool]) -> list[secret bool]:
  return inv_affine(aes_sbox(inv_affine(y)))

def inv_sub_bytes(state: list[list[secret bool]]) -> list[list[secret bool]]:
  # inv_sbox(y) = inv_affine(aes_sbox(inv_affine(y))); inv_affine is linear, so
  # batch the (only non-linear) S-box across all bytes via aes_sbox_vec.
  var pre: list[list[secret bool]] = []
  for i in 0..state.len():
    pre.append(inv_affine(state[i]))
  var mid = aes_sbox_vec(pre)
  var out: list[list[secret bool]] = []
  for i in 0..mid.len():
    out.append(inv_affine(mid[i]))
  return out

def inv_shift_rows(state: list[list[secret bool]]) -> list[list[secret bool]]:
  # Inverse of shift_rows: row r is rotated right by r (state is column-major).
  return [state[0], state[13], state[10], state[7], state[4], state[1], state[14], state[11], state[8], state[5], state[2], state[15], state[12], state[9], state[6], state[3]]

# GF(2^8) multiply-by-constant for the inverse MixColumns matrix. xtime/byte_xor
# are linear (no AND gates), so InvMixColumns adds no multiplication rounds.
def mul9(a: list[secret bool]) -> list[secret bool]:
  return byte_xor(xtime(xtime(xtime(a))), a)

def mul11(a: list[secret bool]) -> list[secret bool]:
  var x2 = xtime(a)
  var x8 = xtime(xtime(x2))
  return byte_xor3(x8, x2, a)

def mul13(a: list[secret bool]) -> list[secret bool]:
  var x4 = xtime(xtime(a))
  var x8 = xtime(x4)
  return byte_xor3(x8, x4, a)

def mul14(a: list[secret bool]) -> list[secret bool]:
  var x2 = xtime(a)
  var x4 = xtime(x2)
  var x8 = xtime(x4)
  return byte_xor3(x8, x4, x2)

def inv_mix_single_column(a0: list[secret bool], a1: list[secret bool], a2: list[secret bool], a3: list[secret bool]) -> list[list[secret bool]]:
  var b0 = byte_xor4(mul14(a0), mul11(a1), mul13(a2), mul9(a3))
  var b1 = byte_xor4(mul9(a0), mul14(a1), mul11(a2), mul13(a3))
  var b2 = byte_xor4(mul13(a0), mul9(a1), mul14(a2), mul11(a3))
  var b3 = byte_xor4(mul11(a0), mul13(a1), mul9(a2), mul14(a3))
  return [b0, b1, b2, b3]

def inv_mix_columns(state: list[list[secret bool]]) -> list[list[secret bool]]:
  var out: list[list[secret bool]] = []
  for col in 0..4:
    var offset: int64 = col * 4
    var mixed = inv_mix_single_column(state[offset], state[offset + 1], state[offset + 2], state[offset + 3])
    out.append(mixed[0])
    out.append(mixed[1])
    out.append(mixed[2])
    out.append(mixed[3])
  return out

def aes128_decrypt_rk(block: list[list[secret bool]], round_key: list[list[secret bool]]) -> list[list[secret bool]]:
  var state = add_round_key(block, round_key, 160)
  for round in 1..10:
    state = inv_shift_rows(state)
    state = inv_sub_bytes(state)
    state = add_round_key(state, round_key, (10 - round) * 16)
    state = inv_mix_columns(state)
  state = inv_shift_rows(state)
  state = inv_sub_bytes(state)
  state = add_round_key(state, round_key, 0)
  return state

def aes128_decrypt(block: list[list[secret bool]], key: list[list[secret bool]]) -> list[list[secret bool]]:
  return aes128_decrypt_rk(block, key_expansion(key))

# ===========================================================================
# Modes of operation (CTR and CBC) over the single-block AES primitive.
#
# IV / nonce / counter blocks are PUBLIC values; only the plaintext and the key
# are secret. Block XOR (`bytes_xor`) is linear, so the modes add no extra
# multiplication rounds beyond the underlying AES block calls.
# ===========================================================================

# Build a (publicly-known) secret-bool block from 16 clear byte values.
def public_byte(value: int64) -> list[secret bool]:
  var bits: list[secret bool] = []
  var v: int64 = value
  for i in 0..8:
    bits.append(Share.from_clear_int(v % 2, 1))   # little-endian: bit i = 2^i
    v = v / 2
  return bits

def public_block(values: list[int64]) -> list[list[secret bool]]:
  var block: list[list[secret bool]] = []
  for i in 0..16:
    block.append(public_byte(values[i]))
  return block

# Read the `block_index`-th 16-byte block of a client's secret input (slot).
def take_client_block_n(client_slot: int64, block_index: int64) -> list[list[secret bool]]:
  var block: list[list[secret bool]] = []
  for byte_index in 0..16:
    block.append(take_client_byte(client_slot, block_index * 16 + byte_index))
  return block

# --- CTR -------------------------------------------------------------------
# keystream_i = AES_enc(counter_i, key);  out_i = data_i XOR keystream_i.
# Encryption and decryption are the same operation, so one function serves both.
def ctr_crypt(blocks: list[list[list[secret bool]]], round_key: list[list[secret bool]], counters: list[list[list[secret bool]]]) -> list[list[list[secret bool]]]:
  var out: list[list[list[secret bool]]] = []
  for i in 0..blocks.len():
    var keystream = aes128_encrypt_rk(counters[i], round_key)
    out.append(bytes_xor(blocks[i], keystream))
  return out

# --- CBC -------------------------------------------------------------------
# C_0 = AES_enc(P_0 XOR IV, key);  C_i = AES_enc(P_i XOR C_{i-1}, key).
def cbc_encrypt(blocks: list[list[list[secret bool]]], key: list[list[secret bool]], iv: list[list[secret bool]]) -> list[list[list[secret bool]]]:
  var out: list[list[list[secret bool]]] = []
  var prev = iv
  for i in 0..blocks.len():
    var c = aes128_encrypt(bytes_xor(blocks[i], prev), key)
    out.append(c)
    prev = c
  return out

# P_0 = AES_dec(C_0, key) XOR IV;  P_i = AES_dec(C_i, key) XOR C_{i-1}.
def cbc_decrypt(cts: list[list[list[secret bool]]], key: list[list[secret bool]], iv: list[list[secret bool]]) -> list[list[list[secret bool]]]:
  var out: list[list[list[secret bool]]] = []
  var prev = iv
  for i in 0..cts.len():
    out.append(bytes_xor(aes128_decrypt(cts[i], key), prev))
    prev = cts[i]
  return out

def main() -> list[int64]:
  # Slot 1 = threshold key (secret-shared); slot 0 = 2 secret plaintext blocks.
  # NIST SP 800-38A AES-128 CTR vector (key 2b7e1516..., ctr0 f0f1...feff).
  var key = take_client_block(1)
  # Expand the threshold key schedule once and reuse it for every block / direction.
  var round_key = key_expansion(key)
  var plaintext = [take_client_block_n(0, 0), take_client_block_n(0, 1)]
  var ctr0 = public_block([240, 241, 242, 243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 254, 255])
  var ctr1 = public_block([240, 241, 242, 243, 244, 245, 246, 247, 248, 249, 250, 251, 252, 253, 255, 0])
  var counters = [ctr0, ctr1]

  # Encrypt, then decrypt (CTR decryption is the SAME operation) to recover P.
  var ct = ctr_crypt(plaintext, round_key, counters)
  print(reveal_block(ct[0]))
  print(reveal_block(ct[1]))
  var pt = ctr_crypt(ct, round_key, counters)
  print(reveal_block(pt[0]))
  print(reveal_block(pt[1]))
  return reveal_block(pt[1])
