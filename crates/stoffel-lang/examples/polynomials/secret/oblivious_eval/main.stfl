# run-args: --client-input 0=3
#
# Oblivious polynomial evaluation: the server's pricing polynomial is
# public, the client's query point is private. Horner's rule runs with
# the accumulator as a share — each step is one share-by-share multiply
# and one share-plus-public addition — and only p(x) is revealed, never
# x itself.

def oblivious_horner(coeffs: list[int64], x: secret int64) -> secret int64:
  var acc: secret int64 = Share.from_clear(0)
  var i: int64 = coeffs.len() - 1
  while i >= 0:
    var scaled: secret int64 = acc * x
    acc = scaled + coeffs[i]
    i -= 1
  return acc

def clear_horner(coeffs: list[int64], x: int64) -> int64:
  var acc: int64 = 0
  var i: int64 = coeffs.len() - 1
  while i >= 0:
    acc = acc * x + coeffs[i]
    i -= 1
  return acc

def main() -> int64:
  # Public tariff: p(x) = 2x^3 - 4x + 5.
  var tariff: list[int64] = [5, -4, 0, 2]

  # The client's consumption level stays secret; only the price is revealed.
  var consumption: secret int64 = ClientStore.take_share(0, 0)
  var price: int64 = oblivious_horner(tariff, consumption).reveal()

  # Documented query point 3: 2*27 - 12 + 5 = 47.
  assert price == clear_horner(tariff, 3), "price matches the clear evaluation"
  assert price == 47, "hand-checked tariff at 3"

  # A second public polynomial evaluated at the same hidden point.
  var bonus: list[int64] = [1, 0, 1]
  var bonus_value: int64 = oblivious_horner(bonus, consumption).reveal()
  assert bonus_value == 10, "x^2 + 1 at the hidden point"

  print(f"price={price}")
  print("oblivious evaluation: the query point was never revealed")
  return 0
